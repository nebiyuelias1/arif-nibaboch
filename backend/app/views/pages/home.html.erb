<div class="min-h-screen flex items-center justify-center">
	<div class="max-w-4xl w-full">
		<div class="bg-surface shadow-md rounded-lg p-6 sm:p-10">
			<div class="flex items-center space-x-4">
				<div class="flex-1">
				<h1 class="title title-lg font-extrabold text-content"> 
						<% if defined?(current_user) && current_user.present? %>
						<%= t("pages.home.greeting_user", user: (current_user.name rescue current_user.to_s)) %>
						<% else %>
							<%= t("pages.home.greeting_guest") %>
						<% end %>
					</h1>
				<p class="mt-2 text-sm text-content-subtle"><%= t("pages.home.dashboard_intro") %></p>
				</div>

				<div class="hidden sm:flex sm:items-center">
				<div class="h-12 w-12 rounded-full bg-background flex items-center justify-center">
					<svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A13.937 13.937 0 0112 15c2.5 0 4.847.63 6.879 1.804M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
						</svg>
					</div>
				</div>
			</div>

			<div class="mt-6 grid gap-4 sm:grid-cols-3">
			<div class="p-4 bg-background rounded-lg shadow-sm">
				<h3 class="text-sm font-semibold text-content"><%= t("pages.home.edit_title") %></h3>
				<p class="mt-1 text-xs text-content-subtle"><%= t("pages.home.edit_description") %></p>
					<div class="mt-3">
					<%= link_to t("pages.home.edit_profile"), edit_user_registration_path, class: "text-primary text-sm font-medium hover:text-accent" %>
					</div>
				</div>

			<div class="p-4 bg-background rounded-lg shadow-sm">
				<h3 class="text-sm font-semibold text-content"><%= t("pages.home.security_title") %></h3>
				<p class="mt-1 text-xs text-content-subtle"><%= t("pages.home.security_description") %></p>
					<div class="mt-3">
					<%= link_to t("pages.home.change_password"), edit_user_registration_path, class: "text-primary text-sm font-medium hover:text-accent" %>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>
