<div class="max-w-3xl mx-auto py-8 sm:py-12">
  <div class="mb-6">
    <%= link_to profile_path, class: "inline-flex items-center text-sm font-medium text-content-subtle hover:text-accent transition-colors group" do %>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 mr-1 group-hover:-translate-x-1 transition-transform">
        <path fill-rule="evenodd" d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z" clip-rule="evenodd" />
      </svg>
      <%= t("devise.registrations.edit.back_to_profile") %>
    <% end %>
  </div>

  <div class="bg-surface rounded-3xl shadow-sm border border-border overflow-hidden">
    <div class="p-6 sm:p-10">
      <div class="mb-8">
        <h1 class="title title-lg text-content font-bold"><%= t("devise.registrations.edit.title") %></h1>
        <p class="mt-2 text-content-subtle"><%= t("devise.registrations.edit.subtitle") %></p>
      </div>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-8" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <%# Account Section %>
        <section class="space-y-6">
          <h2 class="title title-sm text-content font-semibold border-b border-border pb-2"><%= t("devise.registrations.edit.account_information") %></h2>
          
          <div class="grid grid-cols-1 gap-6">
            <div>
              <%= f.label :email, class: "block text-sm font-medium text-content mb-1" %>
              <%= f.email_field :email, autofocus: true, autocomplete: "email", 
                  class: "block w-full px-4 py-3 rounded-xl border-border bg-surface text-content placeholder:text-content-muted focus:border-primary focus:ring-primary sm:text-sm transition-colors" %>
            </div>

            <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
              <div class="rounded-xl bg-yellow-50 p-4 border border-yellow-100">
                <div class="flex">
                  <div class="flex-shrink-0">
                    <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <div class="ml-3">
                    <p class="text-sm text-yellow-700">
                      <%= t("devise.registrations.edit.pending_confirmation", email: resource.unconfirmed_email) %>
                    </p>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </section>

        <%# Password Section %>
        <section class="space-y-6">
          <div class="flex items-center justify-between border-b border-border pb-2">
            <h2 class="title title-sm text-content font-semibold"><%= t("devise.registrations.edit.security") %></h2>
            <span class="text-xs text-content-muted font-normal italic"><%= t("devise.registrations.edit.leave_blank_hint") %></span>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <%= f.label :password, t("devise.registrations.edit.new_password"), class: "block text-sm font-medium text-content mb-1" %>
              <%= f.password_field :password, autocomplete: "new-password", 
                  class: "block w-full px-4 py-3 rounded-xl border-border bg-surface text-content placeholder:text-content-muted focus:border-primary focus:ring-primary sm:text-sm transition-colors" %>
              <% if @minimum_password_length %>
                <p class="mt-2 text-xs text-content-muted"><%= t("devise.shared.characters_minimum", count: @minimum_password_length) %></p>
              <% end %>
            </div>

            <div>
              <%= f.label :password_confirmation, t("devise.registrations.edit.confirm_new_password"), class: "block text-sm font-medium text-content mb-1" %>
              <%= f.password_field :password_confirmation, autocomplete: "new-password", 
                  class: "block w-full px-4 py-3 rounded-xl border-border bg-surface text-content placeholder:text-content-muted focus:border-primary focus:ring-primary sm:text-sm transition-colors" %>
            </div>
          </div>
        </section>

        <%# Confirmation Section %>
        <section class="space-y-6 bg-background rounded-2xl p-6 border border-border">
          <div>
            <h2 class="title title-sm text-content font-semibold mb-1"><%= t("devise.registrations.edit.confirm_changes") %></h2>
            <p class="text-sm text-content-subtle"><%= t("devise.registrations.edit.confirm_changes_description") %></p>
          </div>

          <div>
            <%= f.label :current_password, class: "block text-sm font-medium text-content mb-1" %>
            <%= f.password_field :current_password, autocomplete: "current-password", 
                class: "block w-full px-4 py-3 rounded-xl border-border focus:border-primary focus:ring-primary sm:text-sm bg-surface text-content placeholder:text-content-muted shadow-sm transition-colors" %>
          </div>
        </section>

        <div class="pt-4">
          <%= f.submit t("devise.registrations.edit.save_changes"), class: "w-full flex justify-center py-4 px-4 border border-transparent rounded-2xl shadow-sm text-lg font-bold text-primary-contrast bg-primary hover:bg-primary focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-all cursor-pointer" %>
        </div>
      <% end %>

      <%# Danger Zone %>
      <div class="mt-16 pt-8 border-t border-border">
        <h3 class="title title-sm text-red-600 font-bold mb-2"><%= t("devise.registrations.edit.danger_zone") %></h3>
        <p class="text-sm text-content-subtle mb-6"><%= t("devise.registrations.edit.danger_zone_description") %></p>
        
        <div class="flex items-center justify-between p-6 rounded-2xl border border-red-100 bg-red-50/30">
          <div class="max-w-md">
            <h4 class="title title-sm text-content font-bold"><%= t("devise.registrations.edit.delete_account") %></h4>
            <p class="text-xs text-content-subtle mt-1"><%= t("devise.registrations.edit.delete_account_description") %></p>
          </div>
          <%= button_to t("devise.registrations.edit.delete"), registration_path(resource_name), 
              data: { confirm: t("devise.registrations.edit.delete_confirm"), turbo_confirm: t("devise.registrations.edit.delete_confirm") }, 
              method: :delete, 
              class: "inline-flex items-center px-4 py-2 border border-red-300 shadow-sm text-sm font-medium rounded-xl text-red-700 bg-surface hover:bg-red-50 transition-colors" %>
        </div>
      </div>
    </div>
  </div>
</div>
