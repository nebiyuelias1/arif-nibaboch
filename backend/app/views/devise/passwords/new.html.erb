<div class="min-h-screen bg-background flex items-center justify-center py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full bg-surface shadow-md rounded-lg p-6 sm:p-8 mx-2">
    <div class="text-center mb-5">
      <h2 class="title title-lg text-content font-extrabold">Forgot your password?</h2>
      <p class="mt-1 text-xs sm:text-sm text-content-subtle">Enter your email and we'll send instructions to reset your password.</p>
    </div>

    <% if flash.any? %>
      <% flash.each do |name, msg| %>
        <div class="mb-3 p-3 rounded text-sm <%= name.to_s == 'alert' || name.to_s == 'error' ? 'bg-red-50 text-red-800' : 'bg-background text-content' %>">
          <%= msg %>
        </div>
      <% end %>
    <% end %>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="space-y-3">
        <div>
          <%= f.label :email, class: "block text-sm sm:text-base font-medium text-content" %>
          <div class="mt-1">
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "appearance-none block w-full px-3 py-3 sm:py-2 border border-border rounded-md shadow-sm placeholder:text-content-muted focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary text-sm sm:text-sm text-content bg-surface" %>
          </div>
        </div>

        <div>
        <%= f.submit "Send me reset password instructions", class: "w-full inline-flex items-center justify-center py-3 px-4 border border-transparent rounded-md shadow-sm text-base font-medium text-primary-contrast bg-primary hover:bg-primary focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary" %>
        </div>
      </div>
    <% end %>

  <div class="mt-6 text-center text-sm text-content-subtle">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
