<div style="font-family: sans-serif; max-width: 600px; margin: 0 auto; line-height: 1.6; color: #333;">
  <h2 style="color: #2563eb;"><%= t("mailers.devise.reset_password.title") %></h2>

  <p><%= t("mailers.devise.greeting", email: @resource.email) %></p>

  <p><%= t("mailers.devise.reset_password.intro", app: app_name) %></p>

  <p style="text-align: center; margin: 30px 0;">
    <%= link_to t("mailers.devise.reset_password.change_my_password"), edit_password_url(@resource, reset_password_token: @token), 
        style: "background-color: #2563eb; color: white; padding: 12px 24px; text-decoration: none; border-radius: 5px; font-weight: bold; display: inline-block;" %>
  </p>

  <p><%= t("mailers.devise.reset_password.ignore") %></p>
  <p><%= t("mailers.devise.reset_password.note") %></p>

  <hr style="border: 0; border-top: 1px solid #eee; margin: 30px 0;">

  <p style="font-size: 0.8em; color: #999; text-align: center;">
    <%= t("mailers.devise.footer", year: Time.current.year, app: app_name) %>
  </p>
</div>
