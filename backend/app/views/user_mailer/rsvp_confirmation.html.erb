<h2 style="margin-top: 0; font-weight: 800; font-size: 24px;"><%= t("mailers.rsvp_confirmation.confirmed") %></h2>
<p><%= t("mailers.rsvp_confirmation.hi", name: @user.name) %></p>
<p><%= t("mailers.rsvp_confirmation.intro", club: @book_read.book_club.name) %></p>

<div class="book-card">
  <table border="0" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td width="100" valign="top" style="padding-right: 24px;">
        <% if @book_read.book&.cover_image.present? %>
          <img src="<%= @book_read.book.cover_image %>" style="width: 100px; height: 150px; object-fit: cover; border-radius: 8px;">
        <% else %>
          <div style="width: 100px; height: 150px; background-color: #f7f3ee; border-radius: 8px; border: 1px solid #e4ded6; display: table;">
            <div style="display: table-cell; vertical-align: middle; text-align: center; color: #6b7280; font-size: 11px; font-weight: 600; padding: 10px;"><%= t("books.common.no_cover") %></div>
          </div>
        <% end %>
      </td>
      <td valign="top">
        <h3 class="book-title"><%= @book_read.book&.title || t("mailers.rsvp_confirmation.reading_session") %></h3>
        <p class="book-author"><%= t("mailers.rsvp_confirmation.by_author", author: (@book_read.book&.author || t("mailers.rsvp_confirmation.various_authors"))) %></p>
        <p style="font-size: 14px; color: #6b7280; line-height: 1.5; margin: 0;">
          <%= truncate(@book_read.book&.description, length: 140) %>
        </p>
      </td>
    </tr>
  </table>
</div>

<div style="margin: 32px 0;">
  <div style="margin-bottom: 14px;">
    <span class="details-label"><%= t("mailers.rsvp_confirmation.when") %></span>
    <span class="details-value"><%= @book_read.meetup_time.in_time_zone(@time_zone).strftime("%A, %B %d at %I:%M %p %Z") %></span>
  </div>
  <div style="margin-bottom: 14px;">
    <span class="details-label"><%= t("mailers.rsvp_confirmation.where") %></span>
    <span class="details-value"><%= @book_read.meetup_location %></span>
  </div>
  <div style="margin-bottom: 14px;">
    <span class="details-label"><%= t("mailers.rsvp_confirmation.host") %></span>
    <span class="details-value"><%= @book_read.host.name %></span>
  </div>
</div>

<div style="text-align: center; margin-top: 40px;">
  <%= link_to t("mailers.rsvp_confirmation.view_session_details"), 
      book_club_book_read_url(@book_read.book_club, @book_read), 
      class: "btn-primary" %>
</div>

<p style="margin-top: 40px; font-size: 13px; color: #6b7280; text-align: center; font-style: italic;">
  <%= t("mailers.rsvp_confirmation.calendar_note") %>
</p>
