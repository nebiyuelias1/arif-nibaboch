<div
  data-controller="book-club"
  class="max-w-4xl mx-auto"
  data-book-club-club-id-value="<%= @club.id %>"
>
  <div class="bg-surface rounded-lg shadow-sm overflow-hidden mb-8">
    <% if @club.cover_photo.attached? %>
      <div class="h-64 w-full bg-background relative">
        <%= image_tag @club.cover_photo, class: "w-full h-full object-cover" %>
      </div>
    <% else %>
      <div
        class="
          h-48 w-full bg-primary flex items-center justify-center text-primary-contrast
        "
      >
        <svg
          class="w-16 h-16 opacity-50"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"
          />
        </svg>
      </div>
    <% end %>

    <div class="p-8">
      <div class="flex justify-between items-start">
        <div>
          <h1 class="title title-lg text-content font-bold mb-2"><%= @club.name %></h1>
          <div class="flex items-center space-x-4 mb-6">
            <span
              class="
                inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                <%= @club.is_private ? 'bg-red-100 text-red-800' : 'bg-background text-primary' %>
              "
            >
              <%= @club.is_private ? "Private Club" : "Public Club" %>
            </span>
            <span class="text-sm text-content-subtle">
              Created by
              <%= if @club.owner
                (@club.owner.name.presence || @club.owner.username.presence || "Unknown User")
              else
                "Deleted User"
              end %>
            </span>
          </div>
          <button
            onclick="document.getElementById('members_dialog').showModal()"
            class="
              text-left mt-4 hover:opacity-80 transition-opacity focus:outline-none
              focus:ring-2 focus:ring-offset-2 focus:ring-primary rounded-md block
            "
          >
            <div class="flex items-center gap-2">
              <%= render "shared/avatar_group",
              users: @club.members,
              limit: 5,
              container_classes: "cursor-pointer" %>
              <span class="text-sm text-content-subtle font-medium"><%= pluralize(@club.members.size, "member") %></span>
            </div>
          </button>
        </div>

        <% if user_signed_in? && @club.owner == current_user %>
          <div class="flex space-x-3">
            <%= button_to "Edit Club",
            edit_book_club_path(@club),
            method: :get,
            class:
              "bg-surface border border-border text-content hover:bg-background px-4 py-2 rounded-md text-sm font-medium transition-colors" %>
          </div>
        <% else %>
          <%= button_to @club.has_member?(current_user) ? "Leave Club" : "Join Club",
          book_club_membership_path(@club),
          method: :post,
          id: "book_club_show_join_button",
          form: {
            data: {
              turbo_frame: "_top",
            },
          },
          data: {
            turbo_submits_with:
              @club.has_member?(current_user) ? "Leaving..." : "Joining...",
          },
          class:
            "bg-primary text-primary-contrast hover:bg-primary px-6 py-2 rounded-md text-sm font-medium transition-colors cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed" %>
        <% end %>
      </div>

      <div class="prose max-w-none text-content-subtle mt-6">
        <% if @club.description.present? %>
          <%= simple_format(@club.description) %>
        <% else %>
          <p class="italic text-content-muted">No description provided for this club yet.</p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="flex justify-between items-center mb-6 mt-12">
    <h2 class="title title-sm text-content font-bold">Current Reading</h2>
    <%= link_to "See all",
    book_club_book_reads_path(@club),
    class: "text-primary hover:text-accent text-sm font-medium" %>
  </div>

  <% if @current_read %>
    <%= render partial: "book_reads/card", locals: { read: @current_read } %>
  <% else %>
    <div
      class="
        bg-surface rounded-lg shadow-sm p-8 text-center border border-dashed
        border-border
      "
    >
      <svg
        class="mx-auto h-12 w-12 text-content-muted mb-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
        />
      </svg>
      <h3 class="text-lg font-medium text-content mb-1">No active reading session</h3>
      <p class="text-content-subtle mb-4">The club admin hasn't selected a book to read yet.</p>
      <% if user_signed_in? && @club.owner == current_user %>
        <%= link_to "Start a New Read",
        new_book_club_book_read_path(@club),
        class:
          "inline-flex items-center justify-center bg-background text-primary hover:bg-background px-6 py-2.5 rounded-md text-sm font-medium transition-colors" %>
      <% end %>
    </div>
  <% end %>
</div>

<dialog
  id="members_dialog"
  class="
    p-0 rounded-2xl shadow-2xl backdrop:bg-black/50 w-full max-w-2xl max-h-[80vh]
    open:flex flex-col m-auto
  "
>
  <div
    class="
      flex justify-between items-center p-6 border-b border-border bg-surface sticky
      top-0 z-10
    "
  >
    <h3 class="title title-sm text-content font-semibold">Club Members (<%= @club.members.size %>)</h3>
    <button
      onclick="document.getElementById('members_dialog').close()"
      class="
        text-content-muted hover:text-content focus:outline-none transition-colors
        rounded-full p-1 hover:bg-background
      "
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"
        />
      </svg>
    </button>
  </div>

  <div class="overflow-y-auto p-0 bg-surface">
    <% current_user_is_admin =
      @club.book_club_members.find_by(user: current_user)&.admin? %>
    <% body_content = capture do %>
      <% @club.book_club_members.includes(:user).order(role: :desc, created_at: :asc).each_with_index do |membership, row_idx| %>
        <%= render "book_club_members/member_row",
        membership: membership,
        club: @club,
        is_last: row_idx == @club.book_club_members.size - 1,
        current_user_is_admin: current_user_is_admin %>
      <% end %>
    <% end %>

    <% columns = %w[Member Role Joined] %>
    <% columns << "Actions" if current_user_is_admin %>

    <%= render "shared/table/table",
    columns: columns,
    body_content: body_content,
    hoverable: true,
    sticky_header: true,
    bordered: false,
    container: false %>
  </div>
</dialog>
