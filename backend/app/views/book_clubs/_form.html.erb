<%= form_with(model: @club, local: true, class: "space-y-6") do |form| %> <% if @club.errors.any? %>
    <div class="bg-red-50 text-red-700 p-4 rounded-md">
      <h2 class="font-bold mb-2"><%= pluralize(@club.errors.count, "error") %> prohibited this club from being saved:</h2>
      <ul class="list-disc pl-5">
        <% @club.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :name, class: "w-full border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500", placeholder: "e.g., Sci-Fi Enthusiasts", required: true %>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_area :description, rows: 4, class: "w-full border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500", placeholder: "What is this club about?" %>
  </div>

  <div>
    <%= form.label :cover_photo, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.file_field :cover_photo, class: "w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" %>
  </div>

  <div class="flex items-center">
    <%= form.check_box :is_private, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
    <%= form.label :is_private, "Make this club private (only invited members can join)", class: "ml-2 block text-sm text-gray-900" %>
  </div>

  <div class="flex items-center justify-end space-x-4 pt-4">
    <%= link_to 'Cancel', book_clubs_path, class: "text-gray-500 hover:text-gray-700 font-medium text-sm" %>
    <%= form.submit @club.persisted? ? "Update Club" : "Create Club", class: "bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 font-medium" %>
  </div>
<% end %>
