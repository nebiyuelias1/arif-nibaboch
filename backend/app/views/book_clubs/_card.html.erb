<%#
  Book Club Card Component
  Locals:
    - club: BookClub %>
  <% is_member =
    if local_assigns[:joined_club_ids]
      joined_club_ids.include?(club.id)
    else
      current_user && club.has_member?(current_user)
    end %>
  <% card_class = card_class if local_assigns[:card_class] %>

  <div
    id="<%= dom_id(club) %>"
    class="
      card bg-base-100 shadow-sm w-full h-full <%= card_class %>
    "
  >

    <figure>
      <% if club.cover_photo.attached? %>
        <%= image_tag club.cover_photo, class: "w-full h-32 object-cover" %>
      <% else %>
        <div
          class="
            w-full h-32 bg-background flex items-center justify-center text-content-muted
          "
        >
          <svg class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
            />
          </svg>
        </div>
      <% end %>
    </figure>

    <div class="card-body">
      <!-- Club Name -->
      <div class="card-title">
        <%= club.name %>
      </div>
      <!-- Club Description -->
      <p class="line-clamp-2 min-h-[38px]">
        <%= club.description.presence %>
      </p>
      <!-- Members list block -->
      <div class="flex items-center gap-2 mb-1 mt-auto">
        <%= render "shared/avatar_group",
        users: club.members,
        limit: 5,
        size_classes: "w-6 h-6",
        text_size: "text-[9px]",
        container_classes: "" %>
        <span class="text-xs">
          <%= t("member_count", count: club.members.count) %>
        </span>
      </div>
      <!-- Action Row -->
      <div class="card-actions justify-self-end">
        <!-- Join/Joined toggle button -->
        <%= button_to book_club_membership_path(club),
                  method: :post,
                  form: { onclick: "event.stopPropagation();", class: "grow" },
                  data: { disable_with: is_member ? t("leaving_club") : t("joining_club") },
                  class: is_member ? "w-full btn btn-outline cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed" : "w-full btn btn-primary disabled:opacity-50 disabled:cursor-not-allowed" do %>
          <%= is_member ? t("joined_club") : t("join_club") %>
        <% end %>
      </div>
    </div>
  </div>
