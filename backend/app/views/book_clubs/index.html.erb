<div class="relative min-h-[calc(100vh-8rem)]">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-3xl font-bold text-content">Book Clubs</h1>
  </div>

  <% if @clubs.empty? %>
    <div class="text-center py-12">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-background mb-4">
        <svg class="w-8 h-8 text-content-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
      </div>
      <h3 class="mt-2 text-sm font-semibold text-content">No book clubs</h3>
      <p class="mt-1 text-sm text-content-subtle">Get started by creating a new club.</p>
    </div>
  <% else %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @clubs.each do |club| %>
        <div class="bg-surface rounded-lg shadow overflow-hidden hover:shadow-md transition-shadow duration-200">
          <% if club.cover_photo.attached? %>
            <%= image_tag club.cover_photo, class: "w-full h-48 object-cover" %>
          <% else %>
            <div class="w-full h-48 bg-background flex items-center justify-center text-content-muted">
              <svg class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
          <% end %>
          <div class="p-4">
            <h2 class="text-xl font-bold text-content mb-2"><%= club.name %></h2>
            <p class="text-content-subtle line-clamp-2 text-sm mb-4"><%= club.description %></p>
            <div class="flex items-center justify-between mt-auto">
              <span class="text-xs font-medium px-2.5 py-0.5 rounded-full <%= club.is_private ? 'bg-red-100 text-red-800' : 'bg-background text-primary' %>">
                <%= club.is_private ? 'Private' : 'Public' %>
              </span>
              <%= link_to 'View Club', book_club_path(club), class: "text-primary hover:text-accent text-sm font-medium" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if user_signed_in? %>
    <%= link_to new_book_club_path, class: "fixed bottom-24 right-8 w-14 h-14 bg-primary text-primary-contrast rounded-full flex items-center justify-center shadow-lg hover:bg-primary hover:scale-105 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary group z-50", aria: { label: "Create a new book club" } do %>
      <svg class="w-8 h-8 group-hover:rotate-90 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
    <% end %>
  <% end %>
</div>
