<%= link_to book_club_book_read_path(read.book_club, read), class: "block bg-surface rounded-lg shadow-sm border border-border hover:border-primary transition-colors p-6 flex flex-col sm:flex-row items-start sm:items-center gap-6 group" do %>
  <% if read.book&.cover_image.present? %>
    <div class="w-16 h-24 shrink-0 shadow-sm rounded overflow-hidden">
      <%= image_tag read.book.cover_image, class: "w-full h-full object-cover" %>
    </div>
  <% elsif read.poll.present? %>
    <div class="w-16 h-24 bg-background shrink-0 rounded flex items-center justify-center shadow-inner border border-border">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-primary">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
      </svg>
    </div>
  <% else %>
    <div class="w-16 h-24 bg-background shrink-0 rounded flex items-center justify-center shadow-inner border border-border">
      <svg class="w-6 h-6 text-content-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
      </svg>
    </div>
  <% end %>

  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-3 mb-1">
      <h3 class="title title-sm font-bold text-content truncate group-hover:text-accent transition-colors">
        <%= read.book&.title || read.poll&.text || t("book_reads.card.new_reading_session") %>
      </h3>
    </div>
    
    <% if read.book.present? %>
      <p class="text-sm text-content-subtle mb-2 truncate"><%= t("book_reads.card.by_author", author: read.book.author) %></p>
    <% end %>
    
    <div class="flex items-center text-sm text-content-subtle gap-4">
      <div class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-content-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <span><%= read.meetup_time&.strftime("%b %d, %Y %H:%M") || t("tbd") %></span>
      </div>
      <div class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-content-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <span class="truncate"><%= read.meetup_location.presence || t("tbd") %></span>
      </div>
    </div>
  </div>
  
  <div class="shrink-0 text-primary hidden sm:block">
    <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </div>
<% end %>
