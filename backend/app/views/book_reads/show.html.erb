<div class="max-w-4xl mx-auto mt-8">
  <nav class="flex mb-6" aria-label="Breadcrumb">
    <ol class="inline-flex items-center space-x-1 md:space-x-3">
      <li class="inline-flex items-center">
        <%= link_to "Book Clubs", book_clubs_path, class: "text-sm font-medium text-gray-700 hover:text-blue-600" %>
      </li>
      <li>
        <div class="flex items-center">
          <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
          </svg>
          <%= link_to @book_club.name, book_club_path(@book_club), class: "text-sm font-medium text-gray-700 hover:text-blue-600" %>
        </div>
      </li>
      <li aria-current="page">
        <div class="flex items-center">
          <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
          </svg>
          <span class="text-sm font-medium text-gray-500"><%= @book_read.book.title %></span>
        </div>
      </li>
    </ol>
  </nav>

  <div class="bg-white p-8 rounded-lg shadow-sm border border-gray-100 mb-8">
    <div class="flex flex-col md:flex-row gap-8">
      <div class="w-full md:w-1/3 shrink-0">
        <% if @book_read.book.cover_image.present? %>
          <%= image_tag @book_read.book.cover_image, class: "w-full rounded-lg shadow-md aspect-auto" %>
        <% else %>
          <div class="w-full aspect-[2/3] bg-gray-100 rounded-lg flex items-center justify-center shadow-inner border border-gray-200">
            <span class="text-gray-400 text-sm font-medium">No cover available</span>
          </div>
        <% end %>
      </div>

      <div class="w-full md:w-2/3 flex flex-col">
        <div class="flex justify-between items-start mb-2">
          <h1 class="text-3xl font-bold text-gray-900 leading-tight"><%= @book_read.book.title %></h1>
          <span class="px-3 py-1 rounded-full text-sm font-semibold whitespace-nowrap ml-4
            <%= @book_read.status == 'completed' ? 'bg-green-100 text-green-800' :
                @book_read.status == 'active' ? 'bg-blue-100 text-blue-800' :
                'bg-gray-100 text-gray-800' %>">
            <%= @book_read.status.titleize %>
          </span>
        </div>
        
        <p class="text-xl text-gray-600 mb-6">By <%= @book_read.book.author %></p>

        <div class="bg-blue-50/50 rounded-xl p-6 mb-8 border border-blue-100">
          <h3 class="text-xs font-semibold text-blue-800 uppercase tracking-wider mb-4">Reading Session Details</h3>
          <div class="grid grid-cols-2 gap-6">
            <div>
              <p class="text-sm text-gray-500 mb-1">Start Date</p>
              <p class="font-semibold text-gray-900"><%= @book_read.start_date&.strftime("%B %d, %Y") || 'Not set' %></p>
            </div>
            <div>
              <p class="text-sm text-gray-500 mb-1">End Date</p>
              <p class="font-semibold text-gray-900"><%= @book_read.end_date&.strftime("%B %d, %Y") || 'Not set' %></p>
            </div>
          </div>
        </div>

        <% if @book_read.book.description.present? %>
          <div class="mb-8">
            <h3 class="text-lg font-bold text-gray-900 mb-3">About the Book</h3>
            <p class="text-gray-700 leading-relaxed whitespace-pre-line"><%= @book_read.book.description %></p>
          </div>
        <% end %>

        <div class="mt-auto flex flex-wrap gap-4">
          <%= link_to "View Book Details", book_path(@book_read.book), class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors" %>
          <%= link_to "Back to Club", book_club_path(@book_club), class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors" %>
          <% if user_signed_in? && @book_club.owner == current_user %>
            <%= link_to "Edit Session", edit_book_club_book_read_path(@book_club, @book_read), class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors ml-auto" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Discussion Questions Section -->
  <div class="bg-white p-8 rounded-lg shadow-sm border border-gray-100">
    <h2 class="text-2xl font-bold text-gray-900">Discussion Questions</h2>
    
    <% if user_signed_in? && @book_club.owner == current_user %>
      <div class="mb-6 flex flex-col">
        <%= render partial: "discussion_questions/form", locals: { book_club: @book_club, book_read: @book_read, discussion_question: DiscussionQuestion.new } %>
      </div>
    <% else %>
      <%= turbo_stream_from @book_read, :discussion_questions %>
    <% end %>

    <div id="discussion_questions_list" class="space-y-5">
      <% @discussion_questions.where.not(id: nil).each do |question| %>
        <%= render partial: "discussion_questions/discussion_question", locals: { discussion_question: question } %>
      <% end %>
    </div>

    <div id="no_discussion_questions" class="text-center py-10 bg-gray-50 rounded-lg border border-dashed border-gray-300 mt-4 <%= 'hidden' if @discussion_questions.any? %>">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900">No discussion so far</h3>
      <p class="mt-1 text-sm text-gray-500">Check back later for questions to discuss!</p>
    </div>
  </div>
</div>
