<div class="max-w-4xl mx-auto mt-8">
  <nav class="flex mb-6" aria-label="Breadcrumb">
    <ol class="inline-flex items-center space-x-1 md:space-x-3">
      <li class="inline-flex items-center">
        <%= link_to "Book Clubs",
        book_clubs_path,
        class: "text-sm font-medium text-content-subtle hover:text-accent" %>
      </li>
      <li>
        <div class="flex items-center">
          <svg
            class="w-3 h-3 text-content-muted mx-1"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 6 10"
          >
            <path
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="m1 9 4-4-4-4"
            />
          </svg>
          <%= link_to @book_club.name,
          book_club_path(@book_club),
          class: "text-sm font-medium text-content-subtle hover:text-accent" %>
        </div>
      </li>
      <li aria-current="page">
        <div class="flex items-center">
          <svg
            class="w-3 h-3 text-content-muted mx-1"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 6 10"
          >
            <path
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="m1 9 4-4-4-4"
            />
          </svg>
          <span class="text-sm font-medium text-content-subtle"><%= @book_read.book&.title || "Voting in Progress" %></span>
        </div>
      </li>
    </ol>
  </nav>

  <div class="bg-surface p-8 rounded-lg shadow-sm border border-border mb-8">
    <div class="flex flex-col md:flex-row gap-8">
      <div class="w-full md:w-1/3 shrink-0">
        <% if @book_read.book&.cover_image.present? %>
          <%= image_tag @book_read.book.cover_image,
          class: "w-full rounded-lg shadow-md aspect-auto" %>
        <% elsif @book_read.poll.present? %>
          <div
            class="
              w-full aspect-[2/3] bg-background rounded-lg flex flex-col items-center
              justify-center border border-border
            "
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="w-12 h-12 text-primary mb-4"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"
              />
            </svg>
            <span class="text-primary text-sm font-bold uppercase tracking-wider">Active Poll</span>
          </div>
        <% else %>
          <div
            class="
              w-full aspect-[2/3] bg-background rounded-lg flex items-center justify-center
              shadow-inner border border-border
            "
          >
            <span class="text-content-muted text-sm font-medium">No cover available</span>
          </div>
        <% end %>
      </div>

      <dialog
        id="rsvp_dialog"
        class="
          p-0 rounded-2xl shadow-2xl backdrop:bg-black/50 w-full max-w-2xl max-h-[80vh]
          open:flex flex-col m-auto
        "
      >
        <div
          class="
            flex justify-between items-center p-6 border-b border-border bg-surface sticky
            top-0 z-10
          "
        >
          <h3 class="title title-sm text-content font-semibold">RSVPs (<%= @rsvp_records.size + 1 %>)</h3>
          <button
            onclick="document.getElementById('rsvp_dialog').close()"
            class="
              text-content-muted hover:text-content focus:outline-none transition-colors
              rounded-full p-1 hover:bg-background
            "
          >
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M6 18L18 6M6 6l12 12"
              />
            </svg>
          </button>
        </div>

        <div class="overflow-y-auto p-0 bg-surface">
          <% entries = [] %>
          <% entries << { user: @book_read.host, status: "Host", variant: "blue" } %>
          <% @rsvp_records.each do |rsvp| %>
            <% next if rsvp.user_id == @book_read.host_id %>
            <% variant =
              case rsvp.status
              when "going"
                "green"
              when "waitlisted"
                "yellow"
              else
                "gray"
              end %>
            <% entries << { user: rsvp.user, status: rsvp.status.titleize, variant: variant } %>
          <% end %>

          <% body_content = capture do %>
            <% entries.each_with_index do |entry, row_idx| %>
              <%= render "book_read_rsvps/rsvp_row",
              user: entry[:user],
              status: entry[:status],
              variant: entry[:variant],
              is_last: row_idx == entries.size - 1 %>
            <% end %>
          <% end %>

          <%= render "shared/table/table",
          columns: %w[Person Status],
          body_content: body_content,
          hoverable: true,
          sticky_header: true,
          bordered: false,
          container: false %>
        </div>
      </dialog>

      <div class="w-full md:w-2/3 flex flex-col">
        <div class="flex justify-between items-start mb-2">
          <h1 class="title title-lg text-content font-bold leading-tight">
            <%= @book_read.book&.title || @book_read.poll&.text || "New Reading Session" %>
          </h1>
        </div>

        <% if @book_read.book.present? %>
          <p class="text-xl text-content-subtle mb-3">By
            <%= @book_read.book.author %></p>
        <% end %>
        <button
          onclick="document.getElementById('rsvp_dialog').showModal()"
          class="
            w-full text-left hover:opacity-80 transition-opacity focus:outline-none
            focus:ring-2 focus:ring-offset-2 focus:ring-primary rounded-md
          "
        >
          <div
            class="
              flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-6
            "
          >
            <div class="flex items-center gap-2 text-xs text-content">
              <%= render "shared/avatar",
              user: @book_read.host,
              classes:
                "w-6 h-6 ring-2 ring-surface bg-primary text-primary-contrast text-[9px] font-semibold" %>
              <span>Hosted by:
                <span class="font-semibold"><%= @book_read.host.to_s %></span></span>
            </div>
            <%= render "book_read_rsvps/rsvp_users", rsvp_users: @rsvp_users %>
          </div>
        </button>

        <div class="bg-background rounded-xl p-6 mb-8 border border-border">
          <h3 class="text-xs font-semibold text-primary uppercase tracking-wider mb-4">Meetup Details</h3>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
            <div>
              <p class="text-sm text-content-muted mb-1">When</p>
              <p class="font-semibold text-content"><%= @book_read.meetup_time&.strftime("%B %d, %Y at %H:%M") || "Not set" %></p>
            </div>
            <div>
              <p class="text-sm text-content-muted mb-1">Where</p>
              <p class="font-semibold text-content"><%= @book_read.meetup_location.presence || "Not set" %></p>
            </div>
            <div>
              <p class="text-sm text-content-muted mb-1">Max capacity</p>
              <%= render "book_read_rsvps/capacity_count",
              book_read: @book_read,
              rsvp_users: @rsvp_users %>
            </div>
          </div>
        </div>

        <% if user_signed_in? && current_user != @book_read.host %>
          <%= render "book_reads/rsvp",
          book_club: @book_club,
          book_read: @book_read,
          rsvp: @rsvp %>
        <% end %>

        <% if @book_read.book&.description.present? %>
          <div class="mb-8">
            <h3 class="title title-sm text-content font-bold mb-3">About the Book</h3>
            <p class="text-content-subtle leading-relaxed whitespace-pre-line"><%= @book_read.book.description %></p>
          </div>
        <% end %>

        <div class="mt-auto flex flex-wrap gap-4">
          <% if @book_read.book.present? %>
            <%= link_to "View Book Details",
            book_path(@book_read.book),
            class:
              "inline-flex items-center px-4 py-2 border border-border shadow-sm text-sm font-medium rounded-md text-content bg-surface hover:bg-background focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-colors" %>
          <% end %>
          <%= link_to "Back to Club",
          book_club_path(@book_club),
          class:
            "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-primary-contrast bg-primary hover:bg-primary focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-colors" %>
          <% if user_signed_in? && @book_club.owner == current_user %>
            <%= link_to "Edit Session",
            edit_book_club_book_read_path(@book_club, @book_read),
            class:
              "inline-flex items-center px-4 py-2 border border-border shadow-sm text-sm font-medium rounded-md text-content bg-surface hover:bg-background focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-colors ml-auto" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <% if @book_read.poll.present? %>
    <div class="bg-surface p-8 rounded-lg shadow-sm border border-border mb-8">
      <h2 class="title title-lg text-content font-bold mb-4">Community Poll</h2>
      <p class="text-content-subtle mb-6"><%= @book_read.poll.text %></p>

      <div class="space-y-3">
        <% @book_read.poll.poll_options.each do |option| %>
          <div
            class="
              flex items-center justify-between p-4 rounded-lg border border-border
              bg-background hover:bg-surface transition-all group
            "
          >
            <div class="flex-1">
              <span class="font-bold text-content"><%= option.content %></span>
            </div>
            <button
              class="
                px-5 py-2 bg-surface border border-border rounded-md text-xs font-bold
                text-content hover:border-primary hover:text-primary transition-colors shadow-sm
              "
            >
              Vote
            </button>
          </div>
        <% end %>
      </div>

      <p class="mt-8 text-xs text-content-muted italic text-center">Voting ends on
        <%= @book_read.poll.end_date&.strftime("%B %d, %Y at %I:%M %p") %></p>
    </div>
  <% end %>
  <!-- Discussion Questions Section -->
  <div class="bg-surface p-8 rounded-lg shadow-sm border border-border">
    <h2 class="title title-lg text-content font-bold">Discussion Questions</h2>

    <div class="mb-6 flex flex-col">
      <%= render partial: "discussion_questions/form",
      locals: {
        book_club: @book_club,
        book_read: @book_read,
        discussion_question: @new_discussion_question,
      } %>
    </div>

    <%= turbo_stream_from @book_read, :discussion_questions %>

    <div id="discussion_questions_list" class="space-y-5">
      <% @discussion_questions.where.not(id: nil).each do |question| %>
        <%= render partial: "discussion_questions/discussion_question",
        locals: {
          discussion_question: question,
        } %>
      <% end %>
    </div>

    <div
      id="no_discussion_questions"
      class="
        text-center py-10 bg-background rounded-lg border border-dashed border-border
        mt-4 <%= 'hidden' if @discussion_questions.any? %>
      "
    >
      <svg
        class="mx-auto h-12 w-12 text-content-muted"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.5"
          d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
        />
      </svg>
      <h3 class="mt-2 text-sm font-medium text-content">No discussion so far</h3>
      <p class="mt-1 text-sm text-content-subtle">Check back later for questions to discuss!</p>
    </div>
  </div>
</div>
