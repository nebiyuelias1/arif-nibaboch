<% content_for :title, "#{@book_read.book&.title || @book_read.poll&.text || 'Book Read'} - #{@book_club.name}" %>
<% content_for :og_title, "#{@book_read.book&.title || 'Reading Session'} | #{@book_club.name}" %>
<% content_for :og_description, "Join #{@book_club.name}'s book reading session! Meetup: #{@book_read.meetup_time ? l(@book_read.meetup_time, format: :flyer) : 'TBD'} at #{@book_read.meetup_location.presence || 'TBD'}." %>
<% content_for :og_url, book_club_book_read_url(@book_club, @book_read) %>
<% if @book_read.book.present? && @book_read.book.cover_image.present? %>
  <% content_for :og_image, cover_book_url(@book_read.book) %>
<% end %>

<div class="max-w-4xl mx-auto mt-8">
  <nav class="flex mb-6" aria-label="Breadcrumb">
    <ol class="inline-flex items-center space-x-1 md:space-x-3">
      <li class="inline-flex items-center">
        <%= link_to "Book Clubs",
        book_clubs_path,
        class: "text-sm font-medium text-content-subtle hover:text-accent" %>
      </li>
      <li>
        <div class="flex items-center">
          <svg
            class="w-3 h-3 text-content-muted mx-1"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 6 10"
          >
            <path
              stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"
              stroke-width="2"
              d="m1 9 4-4-4-4"
            />
          </svg>
          <%= link_to @book_club.name,
          book_club_path(@book_club),
          class: "text-sm font-medium text-content-subtle hover:text-accent" %>
        </div>
      </li>
      <li aria-current="page">
        <div class="flex items-center">
          <svg
            class="w-3 h-3 text-content-muted mx-1"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 6 10"
          >
            <path
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="m1 9 4-4-4-4"
            />
          </svg>
          <span class="text-sm font-medium text-content-subtle"><%= @book_read.book&.title || "Voting in Progress" %></span>
        </div>
      </li>
    </ol>
  </nav>

  <div class="bg-surface p-8 rounded-lg shadow-sm border border-border mb-8">
    <div class="flex flex-col md:flex-row gap-8">
      <div class="w-full md:w-1/3 shrink-0">
        <% if @book_read.book&.cover_image.present? %>
          <%= image_tag @book_read.book.cover_image,
          class: "w-full rounded-lg shadow-md aspect-auto" %>
        <% elsif @book_read.poll.present? %>
          <div
            class="
              w-full aspect-[2/3] bg-background rounded-lg flex flex-col items-center
              justify-center border border-border
            "
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="w-12 h-12 text-primary mb-4"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"
              />
            </svg>
            <span class="text-primary text-sm font-bold uppercase tracking-wider">Active Poll</span>
          </div>
        <% else %>
          <div
            class="
              w-full aspect-[2/3] bg-background rounded-lg flex items-center justify-center
              shadow-inner border border-border
            "
          >
            <span class="text-content-muted text-sm font-medium">No cover available</span>
          </div>
        <% end %>
      </div>

      <%= render "book_reads/rsvp_dialog", book_read: @book_read, rsvp_records: @rsvp_records %>

      <%= render "book_reads/share_flyer_dialog", book_club: @book_club, book_read: @book_read %>


      <div class="w-full md:w-2/3 flex flex-col">
        <div class="flex justify-between items-start mb-2">
          <h1 class="title title-lg text-content font-bold leading-tight">
            <%= @book_read.book&.title || @book_read.poll&.text || "New Reading Session" %>
          </h1>
        </div>

        <% if @book_read.book.present? %>
          <p class="text-xl text-content-subtle mb-3">By
            <%= @book_read.book.author %></p>
        <% end %>
        <button
          onclick="document.getElementById('rsvp_dialog').showModal()"
          class="
            w-full text-left hover:opacity-80 transition-opacity focus:outline-none
            focus:ring-2 focus:ring-offset-2 focus:ring-primary rounded-md
          "
        >
          <div
            class="
              flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-6
            "
          >
            <div class="flex items-center gap-2 text-xs text-content">
              <%= render "shared/avatar",
              user: @book_read.host,
              classes:
                "w-6 h-6 ring-2 ring-surface bg-primary text-primary-contrast text-[9px] font-semibold" %>
              <span>Hosted by:
                <span class="font-semibold"><%= @book_read.host.to_s %></span></span>
            </div>
            <%= render "book_read_rsvps/rsvp_users", rsvp_users: @rsvp_users %>
          </div>
        </button>

        <div class="bg-background rounded-xl p-6 mb-8 border border-border">
          <h3 class="text-xs font-semibold text-primary uppercase tracking-wider mb-4">Meetup Details</h3>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
            <div>
              <p class="text-sm text-content-muted mb-1">When</p>
              <p class="font-semibold text-content"><%= @book_read.meetup_time&.strftime("%B %d, %Y at %H:%M") || "Not set" %></p>
            </div>
            <div>
              <p class="text-sm text-content-muted mb-1">Where</p>
              <p class="font-semibold text-content"><%= @book_read.meetup_location.presence || "Not set" %></p>
            </div>
            <div>
              <p class="text-sm text-content-muted mb-1">Max capacity</p>
              <%= render "book_read_rsvps/capacity_count",
              book_read: @book_read,
              rsvp_users: @rsvp_users %>
            </div>
          </div>
        </div>

        <% if user_signed_in? && current_user != @book_read.host %>
          <%= render "book_reads/rsvp",
          book_club: @book_club,
          book_read: @book_read,
          rsvp: @rsvp %>
        <% end %>

        <% if @book_read.book&.description.present? %>
          <div class="mb-8">
            <h3 class="title title-sm text-content font-bold mb-3">About the Book</h3>
            <p class="text-content-subtle leading-relaxed whitespace-pre-line"><%= @book_read.book.description %></p>
          </div>
        <% end %>

        <div class="mt-auto flex gap-3 items-center pt-6 border-t border-border">
          <button
            type="button"
            onclick="document.getElementById('share_flyer_dialog').showModal()"
            class="flex-1 sm:flex-none inline-flex items-center justify-center px-5 py-2.5 border border-transparent shadow-sm text-sm font-semibold rounded-xl text-primary-contrast bg-primary hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-colors gap-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 8.25H7.5a2.25 2.25 0 0 0-2.25 2.25v9a2.25 2.25 0 0 0 2.25 2.25h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25H15m0-3-3-3m0 0-3 3m3-3V15" />
            </svg>
            <%= t("share_flyer") %>
          </button>

          <div class="dropdown dropdown-top sm:dropdown-bottom sm:dropdown-end">
            <button tabindex="0" role="button" class="inline-flex items-center px-4 py-2.5 border border-border shadow-sm text-sm font-medium rounded-xl text-content bg-surface hover:bg-background focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-colors gap-2">
              <span>More Actions</span>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5 text-content-subtle">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </button>
            <ul tabindex="0" class="dropdown-content menu bg-surface border border-border rounded-xl z-[50] w-48 p-1.5 shadow-xl mt-2 mb-2">
              <li>
                <%= link_to book_club_path(@book_club), class: "flex items-center gap-2.5 py-2 px-3 rounded-lg text-content hover:bg-background text-sm font-medium transition-colors" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-content-subtle">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3" />
                  </svg>
                  <%= t("back_to_club") %>
                <% end %>
              </li>

              <% if @book_read.book.present? %>
                <li>
                  <%= link_to book_path(@book_read.book), class: "flex items-center gap-2.5 py-2 px-3 rounded-lg text-content hover:bg-background text-sm font-medium transition-colors" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-content-subtle">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                    </svg>
                    View Book Details
                  <% end %>
                </li>
              <% end %>

              <% if user_signed_in? && @book_club.owner == current_user %>
                <li>
                  <%= link_to edit_book_club_book_read_path(@book_club, @book_read), class: "flex items-center gap-2.5 py-2 px-3 rounded-lg text-content hover:bg-background text-sm font-medium transition-colors" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-content-subtle">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                    </svg>
                    Edit Session
                  <% end %>
                </li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  <% if @book_read.poll.present? %>
    <% poll = @book_read.poll %>
    <% finalized = poll.finalized_at.present? %>
    <% poll_active = poll.active? %>
    
    <div class="bg-surface p-8 rounded-lg shadow-sm border border-border mb-8">
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-3">
          <h2 class="title title-lg text-content font-bold">Poll</h2>
          <% if finalized %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 border border-green-200">
              <svg class="-ml-0.5 mr-1.5 h-2 w-2 text-green-400" fill="currentColor" viewBox="0 0 8 8">
                <circle cx="4" cy="4" r="3" />
              </svg>
              Finalized - Book Selected
            </span>
          <% end %>
        </div>
        
        <div class="flex items-center gap-3">
          <% is_authorized_to_finalize = user_signed_in? && @book_club.owner == current_user %>
          <% if !finalized && !poll_active && is_authorized_to_finalize %>
            <%= link_to "Finalize Poll",
            finalize_book_club_book_read_path(@book_club, @book_read),
            class:
              "inline-flex items-center px-3 py-1.5 text-xs font-semibold rounded-full border border-border bg-background text-content hover:bg-surface transition-colors" %>
          <% end %>
          
          <% unless finalized %>
            <% share_url = "#{request.base_url}#{book_club_book_read_path(@book_club, @book_read)}#poll_voting" %>
            <button
              type="button"
              aria-label="Share poll"
              data-controller="share"
              data-action="share#share"
              data-share-url-value="<%= share_url %>"
              data-share-title-value="<%= poll.text %>"
              class="inline-flex items-center justify-center h-9 w-9 rounded-full border border-border bg-background text-content hover:bg-surface transition-colors"
            >
              <span class="sr-only" data-share-target="label">Share poll</span>
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 12v7a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-7" />
                <path d="M16 6l-4-4-4 4" />
                <path d="M12 2v14" />
              </svg>
            </button>
          <% end %>
        </div>
      </div>

      <% if finalized %>
        <details class="group">
          <summary class="flex items-center justify-between cursor-pointer list-none text-content-subtle hover:text-content transition-colors">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
              <span class="text-sm font-medium">This book was chosen by poll. Click to view results.</span>
            </div>
          </summary>
          <div class="mt-6 pt-6 border-t border-border">
            <p class="text-content-subtle mb-6"><%= poll.text %></p>
            <%= render "polls/vote_results", poll: poll, current_user: current_user %>
            <p class="mt-8 text-xs text-content-muted italic text-center">Voting concluded on <%= poll.finalized_at&.strftime("%B %d, %Y at %I:%M %p") %></p>
          </div>
        </details>
      <% else %>
        <p class="text-content-subtle mb-6"><%= poll.text %></p>
        <% user_has_voted = user_signed_in? && poll.poll_votes.exists?(user_id: current_user.id) %>
        <div id="poll_voting">
          <% if user_has_voted || !poll_active %>
            <%= render "polls/vote_results", poll: poll, current_user: current_user %>
          <% else %>
            <%= render "polls/vote_form", poll: poll, book_club: @book_club, book_read: @book_read %>
          <% end %>
        </div>
        <p class="mt-8 text-xs text-content-muted italic text-center">
          <%= poll_active ? "Voting ends on" : "Voting ended on" %>
          <%= poll.end_date&.strftime("%B %d, %Y at %I:%M %p") %>
        </p>
      <% end %>
    </div>
  <% end %>

  <!-- Discussion Questions Section -->
  <div class="bg-surface p-8 rounded-lg shadow-sm border border-border">
      <h2 class="title title-lg text-content font-bold">Discussion Questions</h2>

      <div class="mb-6 flex flex-col">
        <%= render partial: "discussion_questions/form",
        locals: {
          book_club: @book_club,
          book_read: @book_read,
          discussion_question: @new_discussion_question,
        } %>
      </div>

      <%= turbo_stream_from @book_read, :discussion_questions %>

      <div id="discussion_questions_list" class="space-y-5">
        <% @discussion_questions.where.not(id: nil).each do |question| %>
          <%= render partial: "discussion_questions/discussion_question",
          locals: {
            discussion_question: question,
          } %>
        <% end %>
      </div>

      <div id="no_discussion_questions_wrapper">
        <% if @discussion_questions.where.not(id: nil).empty? %>
          <%= render partial: "discussion_questions/no_questions" %>
        <% end %>
      </div>
    </div>
</div>
