<%= form_with(model: [book_club, book_read], class: "space-y-6") do |form| %>
  <% if @book_read.errors.any? %>
    <div class="bg-red-50 text-red-700 p-4 rounded-md mb-6">
      <h2 class="font-bold"><%= pluralize(@book_read.errors.count, "error") %> prohibited this book read from being saved:</h2>
      <ul class="list-disc pl-5 mt-2 text-sm">
        <% @book_read.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div data-controller="book-autocomplete" data-book-autocomplete-url-value="<%= books_search_path(format: :json) %>" class="relative">
    <%= form.label :book_id, "Select a Book", class: "block text-sm font-medium text-content", for: "book_search_input" %>
    
    <div class="relative mt-1">
      <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
        <svg class="h-5 w-5 text-content-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>
      <input id="book_search_input" 
             type="text" 
             data-book-autocomplete-target="input" 
             data-action="keyup->book-autocomplete#performSearch click->book-autocomplete#performSearch focus->book-autocomplete#performSearch"
             placeholder="Search and select a book..." 
             value="<%= @book_read.book&.title %>"
             autocomplete="off"
             class="pl-10 block w-full rounded-md border-border bg-surface text-content placeholder:text-content-muted shadow-sm focus:border-primary focus:ring-primary sm:text-sm transition-all duration-300">
    </div>

    <%= form.hidden_field :book_id, data: { book_autocomplete_target: "hidden" } %>

    <div data-book-autocomplete-target="results" 
         class="hidden absolute z-50 mt-1 w-full bg-surface shadow-xl max-h-80 rounded-md overflow-y-auto border border-border ring-1 ring-black ring-opacity-5">
    </div>
  </div>

  <div>
    <%= form.label :start_date, class: "block text-sm font-medium text-content" %>
    <%= form.date_field :start_date, class: "mt-1 block w-full rounded-md border-border bg-surface text-content shadow-sm focus:border-primary focus:ring-primary sm:text-sm" %>
  </div>

  <div>
    <%= form.label :end_date, class: "block text-sm font-medium text-content" %>
    <%= form.date_field :end_date, class: "mt-1 block w-full rounded-md border-border bg-surface text-content shadow-sm focus:border-primary focus:ring-primary sm:text-sm" %>
  </div>

  <div>
    <%= form.label :status, class: "block text-sm font-medium text-content" %>
    <%= form.select :status, BookRead.statuses.keys.map { |s| [s.humanize, s] }, {}, class: "mt-1 block w-full rounded-md border-border bg-surface text-content shadow-sm focus:border-primary focus:ring-primary sm:text-sm" %>
  </div>

  <div class="flex justify-end space-x-3 pt-4">
    <%= link_to "Cancel", book_club_path(@book_club), class: "px-4 py-2 border border-border rounded-md shadow-sm text-sm font-medium text-content bg-surface hover:bg-background focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary" %>
    <%= form.submit @book_read.persisted? ? "Update Book Read" : "Start Book Read", class: "px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-primary-contrast bg-primary hover:bg-primary focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary" %>
  </div>
<% end %>
