<%= form_with(model: [book_club, book_read], class: "space-y-6", data: { controller: "poll-toggle" }) do |form| %>
  <% if @book_read.errors.any? %>
    <div class="bg-red-50 text-red-700 p-4 rounded-md mb-6">
      <h2 class="font-bold"><%= pluralize(@book_read.errors.count, "error") %> prohibited this book read from being saved:</h2>
      <ul class="list-disc pl-5 mt-2 text-sm">
        <% @book_read.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-6">
    <label class="text-base font-medium text-gray-900">How would you like to select the book?</label>
    <p class="text-sm leading-5 text-gray-500">Pick a book right away, or let the club vote on it.</p>
    <fieldset class="mt-4">
      <div class="space-y-4 sm:flex sm:items-center sm:space-y-0 sm:space-x-10">
        <div class="flex items-center">
          <input id="mode_select" name="book_selection_mode" type="radio" value="book" data-action="poll-toggle#selectBook" class="focus:ring-blue-500 h-4 w-4 text-blue-600 border-gray-300" <%= 'checked' if @book_read.poll.nil? || (@book_read.poll.new_record? && @book_read.poll.title.blank?) %>>
          <label for="mode_select" class="ml-3 block text-sm font-medium text-gray-700"> Select a Book </label>
        </div>
        <div class="flex items-center">
          <input id="mode_poll" name="book_selection_mode" type="radio" value="poll" data-action="poll-toggle#selectPoll" class="focus:ring-blue-500 h-4 w-4 text-blue-600 border-gray-300" <%= 'checked' if @book_read.poll.present? && !@book_read.poll.title.blank? %>>
          <label for="mode_poll" class="ml-3 block text-sm font-medium text-gray-700"> Create a Poll </label>
        </div>
      </div>
    </fieldset>
  </div>

  <div data-poll-toggle-target="bookSection" data-controller="book-autocomplete" data-book-autocomplete-url-value="<%= books_search_path(format: :json) %>" class="relative">
    <%= form.label :book_id, "Select a Book", class: "block text-sm font-medium text-gray-700", for: "book_search_input" %>
    
    <div class="relative mt-1">
      <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
        <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>
      <input id="book_search_input" 
             type="text" 
             data-book-autocomplete-target="input" 
             data-action="keyup->book-autocomplete#performSearch click->book-autocomplete#performSearch focus->book-autocomplete#performSearch"
             placeholder="Search and select a book..." 
             value="<%= @book_read.book&.title %>"
             autocomplete="off"
             class="pl-10 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm transition-all duration-300">
    </div>

    <%= form.hidden_field :book_id, data: { book_autocomplete_target: "hidden" } %>

    <div data-book-autocomplete-target="results" 
         class="hidden absolute z-50 mt-1 w-full bg-white shadow-xl max-h-80 rounded-md overflow-y-auto border border-gray-200 ring-1 ring-black ring-opacity-5">
    </div>
  </div>

  <div data-poll-toggle-target="pollSection" class="hidden bg-gray-50 p-5 rounded-lg border border-gray-200">
    <h3 class="text-lg font-medium text-gray-900 mb-4">Book Poll</h3>
    <%= form.fields_for :poll do |poll_form| %>
      <div class="mb-4">
        <%= poll_form.label :title, "Poll Question", class: "block text-sm font-medium text-gray-700" %>
        <%= poll_form.text_field :title, placeholder: "e.g., Which book should we read next?", class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
      </div>
      
      <div class="mb-4">
        <%= poll_form.label :description, "Description (Optional)", class: "block text-sm font-medium text-gray-700" %>
        <%= poll_form.text_area :description, rows: 2, placeholder: "Any extra context for the vote...", class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
      </div>

      <div class="space-y-3">
        <label class="block text-sm font-medium text-gray-700">Options for readers to vote on</label>
        <%= poll_form.fields_for :poll_options do |option_form| %>
          <div class="flex items-center space-x-2">
            <%= option_form.text_field :content, placeholder: "Option text (e.g. Book title)", class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <div>
    <%= form.label :start_date, class: "block text-sm font-medium text-gray-700" %>
    <%= form.date_field :start_date, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
  </div>

  <div>
    <%= form.label :end_date, class: "block text-sm font-medium text-gray-700" %>
    <%= form.date_field :end_date, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
  </div>

  <div>
    <%= form.label :status, class: "block text-sm font-medium text-gray-700" %>
    <%= form.select :status, BookRead.statuses.keys.map { |s| [s.humanize, s] }, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
  </div>

  <div class="flex justify-end space-x-3 pt-4">
    <%= link_to "Cancel", book_club_path(@book_club), class: "px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
    <%= form.submit @book_read.persisted? ? "Update Book Read" : "Start Book Read", class: "px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
  </div>
<% end %>
