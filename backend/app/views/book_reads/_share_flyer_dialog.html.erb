<%= render layout: "shared/dialog", locals: { id: "share_flyer_dialog", title: t("share_flyer"), box_class: "bg-surface border border-border shadow-xl rounded-2xl max-w-md p-6 relative" } do %>
  <div data-controller="share-flyer"
       data-share-flyer-club-name-value="<%= book_club.name %>"
       data-share-flyer-title-value="<%= book_read.book&.title || book_read.poll&.text || "Discussion Session" %>"
       data-share-flyer-author-value="<%= book_read.book&.author %>"
       data-share-flyer-time-value="<%= book_read.meetup_time&.strftime("%b %d, %Y - %H:%M") || "TBD" %>"
       data-share-flyer-location-value="<%= book_read.meetup_location.presence || "TBD" %>"
       data-share-flyer-host-value="<%= book_read.host.to_s %>"
       data-share-flyer-cover-url-value="<%= book_read.book&.cover_image.present? ? cover_book_path(book_read.book) : "" %>"
       data-share-flyer-rsvp-url-value="<%= book_club_book_read_url(book_club, book_read) %>"
       data-share-flyer-book-read-id-value="<%= book_read.id %>"
       class="flex flex-col gap-6 items-center">
    
    <!-- Visual Preview of the Flyer (Instagram Story aspect-[9/16] layout to match the high-res 1080x1920 canvas) -->
    <div class="w-full max-w-sm aspect-[9/16] p-6 bg-gradient-to-br from-slate-950 via-indigo-950 to-slate-900 text-white rounded-2xl shadow-2xl flex flex-col gap-4 relative overflow-hidden select-none border border-white/5">
      <!-- Decorative background blur blobs -->
      <div class="absolute top-[10%] right-[-10%] w-40 h-40 bg-indigo-500/10 rounded-full blur-3xl pointer-events-none"></div>
      <div class="absolute bottom-[20%] left-[-10%] w-40 h-40 bg-purple-500/15 rounded-full blur-3xl pointer-events-none"></div>

      <!-- Header: Club info -->
      <div class="flex justify-between items-center border-b border-white/10 pb-3 shrink-0">
        <div class="min-w-0">
          <p class="text-[10px] uppercase tracking-widest text-indigo-300 font-bold">Book Club Meetup</p>
          <h4 class="text-base font-extrabold tracking-tight text-white truncate"><%= book_club.name %></h4>
        </div>
      </div>

      <!-- Main Body: Vertical Stacking for Story Mode -->
      <div class="flex flex-col items-center gap-5 flex-1 min-h-0 overflow-y-auto no-scrollbar">
        <!-- Centered Cover Image (Significantly Enlarged to match canvas scale) -->
        <div class="w-[62%] shrink-0 aspect-[2/3] relative my-1">
          <% if book_read.book&.cover_image.present? %>
            <img src="<%= cover_book_path(book_read.book) %>" 
                 alt="<%= book_read.book.title %>" 
                 class="w-full h-full rounded-2xl shadow-xl border border-white/15 object-cover" />
          <% else %>
            <div class="w-full h-full rounded-2xl bg-white/5 border border-white/10 flex flex-col items-center justify-center text-center p-4 text-slate-400 gap-2 shadow-inner">
              <span class="text-3xl">📝</span>
              <span class="text-[10px] font-bold uppercase tracking-wider text-indigo-300">Active Poll</span>
            </div>
          <% end %>
        </div>

        <!-- Details (Centered & Enlarged) -->
        <div class="w-full flex flex-col gap-1.5 text-center shrink-0">
          <h3 class="font-extrabold text-xl leading-tight text-white line-clamp-2 px-2">
            <%= book_read.book&.title || book_read.poll&.text || "Discussion Session" %>
          </h3>
          <% if book_read.book.present? %>
            <p class="text-sm text-indigo-200 italic font-medium truncate">by <%= book_read.book.author %></p>
          <% end %>
        </div>
      </div>

      <!-- Meetup Info Box (Enlarged and positioned above footer) -->
      <div class="bg-white/5 rounded-xl p-4 border border-white/5 flex flex-col gap-2.5 text-[13px] leading-tight select-none shrink-0">
        <p class="text-[10px] font-bold uppercase tracking-wider text-indigo-300 mb-0.5">Meetup Details</p>
        <!-- Time -->
        <div class="flex items-center gap-2.5 text-slate-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5 text-indigo-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <span class="font-bold truncate"><%= book_read.meetup_time&.strftime("%b %d, %Y - %H:%M") || "TBD" %></span>
        </div>
        <!-- Location -->
        <div class="flex items-center gap-2.5 text-slate-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5 text-indigo-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span class="font-bold truncate"><%= book_read.meetup_location.presence || "TBD" %></span>
        </div>
        <!-- Host -->
        <div class="flex items-center gap-2.5 text-slate-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5 text-indigo-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          <span class="truncate text-slate-300 font-medium">Hosted by <span class="font-bold text-white"><%= book_read.host.to_s %></span></span>
        </div>
      </div>

      <!-- Footer: RSVP QR Code -->
      <div class="flex justify-between items-center border-t border-white/10 pt-3 shrink-0 gap-4 mt-auto">
        <div class="flex-1 min-w-0">
          <p class="text-[10px] font-bold uppercase tracking-wider text-indigo-300">Scan to RSVP</p>
          <p class="text-[9px] text-slate-400 mt-0.5 truncate"><%= book_club_book_read_url(book_club, book_read) %></p>
        </div>
        <!-- QR Code -->
        <div class="w-14 h-14 bg-white p-1 rounded-lg shrink-0 shadow-md flex items-center justify-center">
          <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=<%= CGI.escape(book_club_book_read_url(book_club, book_read)) %>" 
               alt="RSVP QR Code" 
               class="w-full h-full object-contain" />
        </div>
      </div>
    </div>

    <!-- Hidden Canvas used for programmatic drawing in background -->
    <canvas data-share-flyer-target="canvas" class="hidden"></canvas>

    <!-- Actions Panel -->
    <div class="w-full flex gap-3 mt-2">
      <button type="button" 
              data-action="click->share-flyer#download" 
              class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 border border-border shadow-sm text-sm font-medium rounded-xl text-content bg-surface hover:bg-background transition-colors focus:outline-none focus:ring-2 focus:ring-primary">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-content-subtle" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        <%= t("download") %>
      </button>

      <button type="button" 
              data-action="click->share-flyer#share" 
              class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 border border-transparent shadow-sm text-sm font-medium rounded-xl text-primary-contrast bg-primary hover:bg-primary/90 transition-colors focus:outline-none focus:ring-2 focus:ring-primary">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 10.742l5.053 2.526m0-5.109l-5.053 2.526M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <%= t("share") %>
      </button>
    </div>
  </div>
<% end %>
