<div id="<%= dom_id book %>" class="group relative flex flex-col bg-surface radius-card shadow-card card-hover-lift transform transition-all duration-300 border border-border overflow-hidden h-full">
  <%# Image Container %>
  <div class="w-24 flex-shrink-0 shadow-md rounded-lg overflow-hidden">
    <% if book.cover_image.present? %>
      <img src="<%= book.cover_image %>" alt="<%= book.title %>" class="h-full w-full object-cover object-center group-hover:scale-105 transition-transform duration-500">
    <% else %>
      <div class="flex h-full w-full flex-col items-center justify-center bg-background text-content-muted p-4 text-center">
        <svg class="h-12 w-12 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
        <span class="text-xs font-medium text-content-muted"><%= t("books.common.no_cover") %></span>
      </div>
    <% end %>

    <%# Desktop Hover Actions %>
    <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-200 hidden sm:flex items-center justify-center gap-3 backdrop-blur-[2px]">
      <%= link_to book, class: "p-2.5 bg-surface/90 rounded-full hover:bg-surface text-content shadow-sm transition-all hover:scale-110", title: t("books.card.view_details") do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
        </svg>
      <% end %>
    </div>
  </div>

  <%# Card Body %>
  <div class="flex-1 flex flex-col gap-2">

      <h3 class="text-xl font-bold text-gray-800 leading-tight">
        <%= link_to book.title, book, class: "focus:outline-none" %>
      </h3>
      <p class="text-sm italic text-gray-500 mt-0.5">
        <%= book.author.presence || t("books.common.unknown_author") %>
      </p>

      <%# Rating Row %>
      <div class="flex items-center gap-1.5 mb-auto">
        <div class="flex text-accent">
           <%# Simple star logic or just one star with number %>
           <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
           </svg>
        </div>
        <span class="text-sm font-bold text-content"><%= book.average_rating %></span>
        <span class="text-xs text-content-muted">
          (<%= book.reviews_count %>)
        </span>
    </div>

    <%# Footer / Mobile Actions %>
      <div class="mt-4 pt-3 border-t border-border flex items-center justify-between text-content-muted">
      <span class="text-xs font-semibold tracking-wider"><%= book.published_at&.strftime('%Y') || t("books.common.unknown") %></span>
    </div>
  </div>
</div>
