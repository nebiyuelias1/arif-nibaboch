<div class="card card-side bg-base-100 shadow-sm">
  <%# Image Container %>
  <div class="relative aspect-[2/3] w-full overflow-hidden bg-background">
    <% if book.cover_image.present? %>
      <img src="<%= book.cover_image %>" alt="<%= book.title %>" class="h-full w-full object-cover object-center group-hover:scale-105 transition-transform duration-500">
      <% else %>
      <div class="flex h-full w-full flex-col items-center justify-center bg-background text-content-muted p-4 text-center">
        <svg class="h-12 w-12 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
        <span class="text-xs font-medium text-content-muted"><%= t("books.common.no_cover") %></span>
    <% end %>
  </div>
  <div class="card-body">
    <h2 class="card-title">
     <%= link_to book.title, book, class: "focus:outline-none" %>
    </h2>
    <p>
     <%= book.author.presence || t("books.common.unknown_author") %>
    </p>
  </div>
</div>