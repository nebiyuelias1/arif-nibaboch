<footer class="bg-background border-t border-primary mt-auto">
  <div class="container mx-auto px-4 py-8 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-2">
        <%= render "shared/logo", class: "h-6 w-auto text-primary" %>
        <!-- 
          <span class="title title-sm font-bold text-primary"><%= app_name %></span>
        -->
      </div>
      
      <div class="flex flex-wrap justify-center gap-x-8 gap-y-2">
        <%= link_to t("library_footer"), books_path, class: "text-sm text-primary hover:text-accent" %>
        <% if user_signed_in? %>
          <%= link_to t("profile_menu"), profile_path, class: "text-sm text-primary hover:text-accent" %>
        <% end %>
        <%= link_to t("privacy_footer"), privacy_path, class: "text-sm text-primary hover:text-accent" %>
        <%= link_to t("terms_footer"), terms_path, class: "text-sm text-primary hover:text-accent" %>
      </div>

      <p class="text-sm text-primary">
        &copy; <%= Time.current.year %> <%= app_name %>
      </p>
    </div>
  </div>
</footer>
