<header class="bg-background border-b border-primary sticky top-0 z-50 hotwire-native:hidden">
  <nav class="container mx-auto px-4 sm:px-6 lg:px-8" aria-label="Top">
    <div class="flex h-16 items-center justify-between">
      <div class="flex items-center">
        <%= link_to root_path, class: "flex items-center gap-2 group" do %>
          <div class="flex items-center justify-center w-8 h-8 rounded-lg bg-primary text-primary-contrast group-hover:bg-primary transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
              <path d="M11.25 4.533A9.707 9.707 0 006 3.75a9.753 9.753 0 00-3.25.557.75.75 0 00-.5.713v13.715a.75.75 0 00.5.713A9.753 9.753 0 006 18.75c1.278 0 2.481-.237 3.618-.672.779-.298 1.631-.298 2.41 0a9.753 9.753 0 003.618.672c1.24 0 2.417-.22 3.503-.614a.75.75 0 00.5-.713V3.75a.75.75 0 00-.5-.713A9.75 9.75 0 0018 3.75c-1.278 0-2.481.237-3.618.672-.779.298-1.631.298-2.41 0zM12 5.34a9.707 9.707 0 01-3.75-.765V17.91a9.709 9.709 0 003.75.765v-13.333z" />
            </svg>
          </div>
          <span class="title title-sm font-bold tracking-tight text-primary"><%= app_name %></span>
        <% end %>
      </div>
      
      <div class="ml-10 space-x-4 flex items-center">
        <% if user_signed_in? %>
          <div class="hidden sm:flex items-center gap-3">
            <span class="text-sm text-content-subtle"><%= t("welcome_message", user: current_user.to_s) %></span>
          </div>
        <% else %>
          <div class="hidden sm:flex items-center gap-3">
            <%= link_to t("sign_in"), new_user_session_path, data: { turbo: false }, class: "btn-secondary text-primary" %>
            <%= link_to t("sign_up"), new_user_registration_path, data: { turbo: false }, class: "btn-primary" %>
          </div>
        <% end %>

        <!-- Language Switcher Dropdown (DaisyUI) -->
        <div class="dropdown dropdown-end ml-2">
          <div tabindex="0" role="button" class="btn btn-ghost btn-circle flex items-center justify-center focus:outline-none">
            <svg class="w-6 h-6 animate-pulse-slow text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
            </svg>
          </div>
          <ul tabindex="0" class="menu dropdown-content bg-surface border border-primary rounded-box z-50 w-40 p-2 shadow-xl">
            <li>
              <%= link_to "English", url_for(locale: :en), class: "text-primary hover:text-accent #{I18n.locale == :en ? 'active font-bold' : ''}" %>
            </li>
            <li>
              <%= link_to "አማርኛ", url_for(locale: :am), class: "text-primary hover:text-accent #{I18n.locale == :am ? 'active font-bold' : ''}" %>
            </li>
            <li>
              <%= link_to "简体中文", url_for(locale: :"zh-CN"), class: "text-primary hover:text-accent #{I18n.locale == :"zh-CN" ? 'active font-bold' : ''}" %>
            </li>
            <li>
              <%= link_to "繁體中文", url_for(locale: :"zh-TW"), class: "text-primary hover:text-accent #{I18n.locale == :"zh-TW" ? 'active font-bold' : ''}" %>
            </li>
          </ul>
        </div>

        <div class="hidden sm:block ml-2">
          <div class="dropdown dropdown-end">
            <div tabindex="0" role="button" class="btn btn-ghost btn-circle flex items-center justify-center focus:outline-none">
              <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
              </svg>
            </div>
            
            <ul tabindex="0" class="menu dropdown-content bg-surface border border-primary rounded-box z-50 w-56 p-2 shadow-xl">
              <% main_navigation_items.each do |item| %>
                <% is_active = is_active_nav_item?(item) %>
                <li>
                  <%= link_to item[:path], class: "flex items-center gap-3 transition-colors group/link #{is_active ? 'active font-bold text-primary' : 'text-primary'}" do %>
                    <svg class="w-5 h-5 transition-colors <%= is_active ? 'text-primary' : 'text-primary group-hover/link:text-accent' %>" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <%= item[:icon].html_safe %>
                    </svg>
                    <%= item[:name] %>
                  <% end %>
                </li>
              <% end %>
            </ul>
          </div>
        </div>

        <%# Mobile Menu Button Placeholder - simple pure CSS or JS toggle needed for real implementation %>
        <div class="sm:hidden">
          <% unless user_signed_in? %>
            <%= link_to t("sign_in"), new_user_session_path, data: { turbo: false }, class: "btn-secondary text-primary" %>
          <% end %>
        </div>
      </div>
    </div>
  </nav>
</header>
