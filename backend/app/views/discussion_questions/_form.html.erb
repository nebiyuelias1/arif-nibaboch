<div id="new_discussion_question_form">
  <% if user_signed_in? && book_club.owner == current_user %>
    <%= form_with model: [book_club, book_read, discussion_question], class: "flex flex-col", data: { controller: "reset-form", action: "turbo:submit-end->reset-form#reset" } do |form| %>
      <%= form.text_area :content, size: "autox2", required: true, class: "bg-neutral-secondary-medium border border-default-medium text-heading text-sm rounded-base focus:ring-brand focus:border-brand block w-full p-3.5 shadow-xs placeholder:text-body", placeholder: "Write Your Question" %>
      <%= form.button class: "inline-flex items-end px-3 py-1.5 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors shadow-sm self-end mt-2" do %>
        <svg class="-ml-0.5 mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
        </svg>
        Add Question
      <% end %>
    <% end %>
  <% end %>
</div>