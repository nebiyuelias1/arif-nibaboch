<div id="<%= dom_id(discussion_question) %>" class="p-4 bg-gray-50 rounded-lg border border-gray-200">
  <p class="text-gray-800"><%= discussion_question.content %></p>
  <% if discussion_question.draft? %>
    <span class="inline-flex items-center mt-2 px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
      Draft
    </span>
  <% end %>
</div>