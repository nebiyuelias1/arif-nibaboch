<div class="space-y-3">
  <% poll.poll_options.includes(:poll_votes, :book).each do |option| %>
    <% user_voted = current_user.present? && option.poll_votes.any? { |vote| vote.user_id == current_user.id } %>
    <div
      class="
        flex items-center justify-between p-4 rounded-lg border border-border
        bg-background
      "
    >
      <div class="flex items-center gap-4">
        <% if option.book.present? %>
          <div class="flex items-center gap-3">
            <% if option.book.cover_image.present? %>
              <%= image_tag option.book.cover_image, class: "w-10 h-14 object-cover rounded shadow-sm shrink-0" %>
            <% else %>
              <div class="w-10 h-14 bg-background border border-border rounded flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-content-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
              </div>
            <% end %>
            <div class="flex flex-col">
              <div class="flex items-center gap-2">
                <span class="font-bold text-content leading-tight"><%= option.book.title %></span>
                <% if user_voted %>
                  <div class="flex items-center justify-center w-5 h-5 rounded-full bg-green-500 text-white shrink-0" title="Your vote">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5">
                      <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
                    </svg>
                  </div>
                <% end %>
              </div>
              <span class="text-xs text-content-subtle"><%= option.book.author %></span>
              <%= link_to "View details", book_path(option.book), class: "text-[10px] text-primary hover:underline mt-1" %>
            </div>
          </div>
        <% else %>
          <div class="flex items-center gap-3">
            <span class="font-bold text-content"><%= option.content %></span>
            <% if user_voted %>
              <div class="flex items-center justify-center w-5 h-5 rounded-full bg-green-500 text-white shrink-0" title="Your vote">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5">
                  <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
                </svg>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
      <span class="text-xs font-semibold text-content-muted">
        <%= pluralize(option.poll_votes.size, "vote") %>
      </span>
    </div>
  <% end %>
</div>
