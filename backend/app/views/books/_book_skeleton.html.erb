 <div class="card card-side bg-base-100 shadow-sm">
  <%# Image Container Skeleton %>
  <div class="w-24 flex-shrink-0 shadow-md rounded-lg overflow-hidden"></div>

  <%# Card Body Skeleton %>
 <div class="flex-1 flex flex-col gap-2">
    <div class="flex-1">
      <%# Title Skeleton %>
      <div class="h-5 bg-border rounded w-3/4 mb-2"></div>
      <div class="h-5 bg-border rounded w-1/2 mb-4"></div>

      <%# Author Skeleton %>
      <div class="h-4 bg-background rounded w-1/3 mb-4"></div>

      <%# Rating Row Skeleton %>
      <div class="flex items-center gap-1.5 mb-3">
        <div class="w-4 h-4 bg-border rounded-full"></div>
        <div class="h-4 bg-border rounded w-8"></div>
        <div class="h-3 bg-background rounded w-12"></div>
      </div>
    

    <%# Footer Skeleton %>
    <div class="mt-3 pt-3 border-t border-border flex items-center justify-between">
      <div class="h-3 bg-background rounded w-12"></div>
      <div class="flex gap-3">
        <div class="w-5 h-5 bg-background rounded"></div>
        <div class="w-5 h-5 bg-background rounded"></div>
      </div>
    </div>
  </div>
</div>
