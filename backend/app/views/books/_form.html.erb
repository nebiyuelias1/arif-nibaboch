<%= form_with(model: book, local: true, class: 'space-y-4') do |form| %>
  <% if book.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-700 p-3 rounded">
      <strong><%= t("books.form.errors", count: book.errors.count) %></strong>
      <ul class="mt-2 list-disc list-inside">
        <% book.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, class: 'block text-sm font-medium text-content' %>
    <%= form.text_field :title, class: 'mt-1 block w-full border-border bg-surface text-content rounded-md shadow-sm focus:ring-primary focus:border-primary placeholder:text-content-muted' %>
  </div>

  <div>
    <%= form.label :author, class: 'block text-sm font-medium text-content' %>
    <%= form.text_field :author, class: 'mt-1 block w-full border-border bg-surface text-content rounded-md shadow-sm focus:ring-primary focus:border-primary placeholder:text-content-muted' %>
  </div>

  <div>
    <%= form.label :published_at, class: 'block text-sm font-medium text-content' %>
    <%= form.date_field :published_at, class: 'mt-1 block w-full border-border bg-surface text-content rounded-md shadow-sm focus:ring-primary focus:border-primary' %>
  </div>

  <div>
    <%= form.label :description, class: 'block text-sm font-medium text-content' %>
    <%= form.text_area :description, rows: 6, class: 'mt-1 block w-full border-border bg-surface text-content rounded-md shadow-sm focus:ring-primary focus:border-primary placeholder:text-content-muted' %>
  </div>

  <div class="pt-2">
    <%= form.submit class: 'inline-block bg-primary text-primary-contrast px-4 py-2 rounded hover:bg-primary' %>
  </div>
<% end %>
