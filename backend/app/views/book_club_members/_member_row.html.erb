<%
  is_last ||= false
  current_user_is_admin ||= false
%>
<tr id="<%= dom_id(membership) %>" class="hover:bg-background transition-colors <%= is_last ? '' : '[box-shadow:inset_0_-1px_0_0_rgb(229_224_211)]' %>">
  <td class="px-6 py-4 whitespace-nowrap">
    <div class="flex items-center">
      <div class="shrink-0 h-10 w-10">
        <%= render "shared/avatar", user: membership.user, classes: "w-10 h-10 ring-2 ring-surface bg-primary text-primary-contrast text-sm font-semibold" %>
      </div>
      <div class="ml-4">
        <div class="text-sm font-medium text-content"><%= membership.user.name.presence || membership.user.username.presence || "No Name Provided" %></div>
        <div class="text-sm text-content-subtle"><%= membership.user.email %></div>
      </div>
    </div>
  </td>
  <td class="px-6 py-4 whitespace-nowrap">
    <% if membership.user_id == club.owner_id %>
      <%= render "shared/badge/badge", text: "Owner", variant: "blue", pill: true %>
    <% elsif membership.admin? %>
      <%= render "shared/badge/badge", text: "Admin", variant: "purple", pill: true %>
    <% else %>
      <%= render "shared/badge/badge", text: "Member", variant: "neutral", pill: true %>
    <% end %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-content-subtle">
    <%= membership.created_at.strftime("%b %d, %Y") %>
  </td>
  <% if current_user_is_admin %>
    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-right">
      <% unless membership.user_id == club.owner_id %>
        <% trigger_html = capture do %>
          <button type="button" class="inline-flex items-center justify-center p-1.5 rounded-full text-content-muted hover:text-content hover:bg-background transition-colors focus:outline-none">
            <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z" />
            </svg>
          </button>
        <% end %>

        <%= render("shared/popover/popover", trigger_type: "click", placement: "bottom-end", interactive: true, arrow: false, trigger_html: trigger_html, classes: "w-full flex justify-end") do %>
          <div class="flex flex-col min-w-[170px] p-1 bg-surface">
            <% if membership.admin? %>
              <%= button_to book_club_member_path(club, membership, role: :member), method: :patch, form: { class: "w-full" }, class: "group flex w-full items-center gap-2 px-3 py-2 text-sm font-medium text-content-subtle rounded-md hover:bg-background hover:text-content transition-colors" do %>
                <svg class="h-4 w-4 text-content-muted group-hover:text-content" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
                Demote to Member
              <% end %>
            <% else %>
              <%= button_to book_club_member_path(club, membership, role: :admin), method: :patch, form: { class: "w-full" }, class: "group flex w-full items-center gap-2 px-3 py-2 text-sm font-medium text-content-subtle rounded-md hover:bg-background hover:text-content transition-colors" do %>
                <svg class="h-4 w-4 text-content-muted group-hover:text-content" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
                Make Admin
              <% end %>
            <% end %>

            <div class="h-px bg-border my-1 -mx-1"></div>

            <%= button_to book_club_member_path(club, membership), method: :delete, data: { turbo_confirm: "Are you sure you want to remove this member?" }, form: { class: "w-full" }, class: "group flex w-full items-center gap-2 px-3 py-2 text-sm font-medium text-red-600 rounded-md hover:bg-red-50 hover:text-red-700 transition-colors" do %>
              <svg class="h-4 w-4 text-red-500 group-hover:text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
              Remove Member
            <% end %>
          </div>
        <% end %>
      <% end %>
    </td>
  <% end %>
</tr>
