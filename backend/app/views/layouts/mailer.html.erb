<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <style type="text/css">
      /* 
         We use hardcoded hex values here because email clients 
         (Gmail/Outlook) do not support CSS Variables or @import. 
         Premailer-rails will take these and put them inline.
      */
      body {
        background-color: #f7f3ee;
        font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        margin: 0;
        padding: 0;
        width: 100% !important;
      }
      .container-email {
        max-width: 600px;
        margin: 40px auto;
        background-color: #ffffff;
        border-radius: 16px;
        border: 1px solid #e4ded6;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
      }
      .header {
        background-color: #22324a;
        padding: 40px 32px;
        text-align: center;
      }
      .header h1 {
        color: #ffffff;
        margin: 0;
        font-size: 26px;
        font-weight: 800;
      }
      .content {
        padding: 40px 32px;
        color: #1f2430;
        font-size: 16px;
        line-height: 1.6;
      }
      .footer {
        padding: 24px;
        text-align: center;
        font-size: 12px;
        color: #6b7280;
        background-color: #f7f3ee;
        border-top: 1px solid #e4ded6;
      }
      .btn-primary {
        display: inline-block;
        background-color: #22324a;
        color: #ffffff !important;
        padding: 16px 32px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 700;
        font-size: 16px;
      }
      .book-card {
        background-color: #ffffff;
        border: 1px solid #e4ded6;
        border-radius: 16px;
        padding: 24px;
        margin: 24px 0;
      }
      .book-title {
        font-size: 20px;
        font-weight: 800;
        color: #1f2430;
        margin: 0 0 4px 0;
      }
      .book-author {
        font-size: 15px;
        color: #4b5563;
        margin: 0 0 16px 0;
      }
      .details-label {
        color: #6b7280;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 11px;
        letter-spacing: 0.05em;
        width: 100px;
        display: inline-block;
      }
      .details-value {
        color: #1f2430;
        font-weight: 600;
      }
    </style>
  </head>

  <body>
    <div class="container-email">
      <div class="header">
        <h1><%= Rails.configuration.x.app_name %></h1>
      </div>
      
      <div class="content">
        <%= yield %>
      </div>
      
      <div class="footer">
        &copy; <%= Time.now.year %> <%= Rails.configuration.x.app_name %>. All rights reserved.
      </div>
    </div>
  </body>
</html>
